<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="BgColor">#15171C</Color>
  <Color x:Key="PanelColor">#1E232B</Color>
  <Color x:Key="BorderColor">#2E3642</Color>
  <Color x:Key="TextColor">#E8ECF2</Color>
  <Color x:Key="MutedTextColor">#9AA4B2</Color>
  <Color x:Key="AccentColor">#5C8DFF</Color>
  <Color x:Key="SuccessColor">#38D39F</Color>
  <Color x:Key="DangerColor">#FF5D73</Color>

  <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
  <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}"/>
  <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
  <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
  <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}"/>
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
  <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>

  <Style Selector="Window">
    <Setter Property="Background" Value="{StaticResource BgBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
  </Style>

  <Style Selector="Border.card">
    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="12"/>
    <Setter Property="Padding" Value="12"/>
  </Style>

  <Style Selector="Button">
    <Setter Property="Background" Value="#2C3441"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="#3D495B"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="10,6"/>
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="#364256"/>
  </Style>
</ResourceDictionary>
