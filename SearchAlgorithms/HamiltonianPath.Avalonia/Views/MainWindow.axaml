<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HamiltonianPath.Avalonia.Views.Controls"
        xmlns:local="clr-namespace:HamiltonianPath.Avalonia.Converters"
        x:Class="HamiltonianPath.Avalonia.Views.MainWindow"
        Title="Гамильтонов путь"
        Width="1440"
        Height="920"
        MinWidth="1180"
        MinHeight="760">
  <Grid>
    <Grid ColumnDefinitions="380,18,*" Margin="18" IsEnabled="{Binding IsInteractionEnabled}">
      <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
        <Border Classes="card">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title" Text="Настройка поля" />
            <Grid ColumnDefinitions="*,10,*">
              <StackPanel Grid.Column="0">
                <TextBlock Classes="caption" Text="Ширина" />
                <NumericUpDown Minimum="2" Maximum="20" Value="{Binding PendingBoardWidth}" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Classes="caption" Text="Высота" />
                <NumericUpDown Minimum="2" Maximum="20" Value="{Binding PendingBoardHeight}" />
              </StackPanel>
            </Grid>
            <WrapPanel>
              <Button Width="170" Classes="secondary-action" Content="Применить размер" Command="{Binding ResizeBoardCommand}" />
              <Button Width="170" Classes="secondary-action" Content="Очистить стены" Command="{Binding ClearWallsCommand}" />
              <Button Width="170" Classes="secondary-action" Content="Сбросить" Command="{Binding ClearAllCommand}" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title" Text="Инструменты редактирования" />
            <WrapPanel Orientation="Horizontal" ItemHeight="40">
              <Button x:Name="StartToolButton" Width="120" Classes="toolbar-chip" Content="Старт" Click="StartToolButton_Click" />
              <Button x:Name="FinishToolButton" Width="120" Classes="toolbar-chip" Content="Финиш" Click="FinishToolButton_Click" />
              <Button x:Name="WallToolButton" Width="120" Classes="toolbar-chip" Content="Стены" Click="WallToolButton_Click" />
              <Button x:Name="EraseToolButton" Width="120" Classes="toolbar-chip" Content="Ластик" Click="EraseToolButton_Click" />
            </WrapPanel>
            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Classes="caption" />
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="8">
            <TextBlock Classes="section-title" Text="Модификации" />
            <CheckBox Content="Эвристика Варнсдорфа" IsChecked="{Binding UseWarnsdorff}" />
            <CheckBox Content="Отсечение по связности" IsChecked="{Binding UseConnectivity}" />
            <CheckBox Content="Backjumping" IsChecked="{Binding UseBackjumping}" />
            <WrapPanel Orientation="Horizontal">
              <Button Classes="primary-action solve-action" Content="Запустить" Command="{Binding RunCurrentCommand}" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="10">
            <DockPanel>
              <TextBlock DockPanel.Dock="Left" Classes="section-title" Text="Результаты" />
              <Button DockPanel.Dock="Right" Width="170" Classes="secondary-action" Content="Очистить результаты" Command="{Binding ClearResultsCommand}" />
            </DockPanel>
            <ItemsControl ItemsSource="{Binding Results}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="result-item">
                    <StackPanel Spacing="8">
                      <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="{Binding Title}" FontWeight="SemiBold" />
                        <TextBlock DockPanel.Dock="Right" Classes="caption" Text="{Binding ExecutedAt, StringFormat='{}{0:HH:mm:ss}'}" />
                      </DockPanel>
                      <TextBlock Text="{Binding StatusText}" />
                      <WrapPanel>
                        <Border Classes="metric-badge"><TextBlock Text="{Binding Elapsed.TotalMilliseconds, StringFormat='{}Время: {0:0.##} ms'}" /></Border>
                        <Border Classes="metric-badge"><TextBlock Text="{Binding ManagedMemoryDeltaBytes, Converter={x:Static local:ByteSizeConverter.Instance}, StringFormat='{}Память: {0}'}" /></Border>
                        <Border Classes="metric-badge"><TextBlock Text="{Binding Steps, StringFormat='{}Шагов: {0}'}" /></Border>
                      </WrapPanel>
                      <TextBlock Classes="caption" TextWrapping="Wrap" Text="{Binding Note}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
        </StackPanel>
      </ScrollViewer>

      <Grid Grid.Column="2" RowDefinitions="Auto,14,*">
        <Border Classes="card" Padding="16">
          <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <TextBlock Classes="section-title" Text="Сетка" />
          </StackPanel>
        </Border>
        <controls:HamiltonianBoardView Grid.Row="2" />
      </Grid>
    </Grid>

    <Border IsVisible="{Binding IsBusy}"
            Background="#AA12141A"
            ZIndex="99">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Classes="card"
              Padding="20">
        <StackPanel Spacing="12" Width="280">
          <TextBlock Classes="section-title"
                     Text="Выполняется анализ"
                     HorizontalAlignment="Center" />
          <TextBlock Classes="caption"
                     Text="Пожалуйста, подождите или прервите выполнение."
                     TextWrapping="Wrap"
                     HorizontalAlignment="Center"
                     TextAlignment="Center" />
          <ProgressBar IsIndeterminate="True" Height="8" />
          <Button Content="Прервать"
                  Classes="secondary-action"
                  Command="{Binding CancelRunCommand}" />
        </StackPanel>
      </Border>
    </Border>
  </Grid>
</Window>
