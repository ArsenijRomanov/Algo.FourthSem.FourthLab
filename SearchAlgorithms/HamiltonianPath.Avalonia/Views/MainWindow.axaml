<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HamiltonianPath.Avalonia.Views.Controls"
        xmlns:local="clr-namespace:HamiltonianPath.Avalonia.Converters"
        x:Class="HamiltonianPath.Avalonia.Views.MainWindow"
        Title="Лабораторная: гамильтонов путь"
        Width="1440"
        Height="920"
        MinWidth="1180"
        MinHeight="760">
  <Grid ColumnDefinitions="380,18,*" Margin="18">
    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="16">
        <Border Classes="card">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title" Text="Настройка поля" />
            <TextBlock Classes="caption" Text="Задайте размер, выберите инструмент, поставьте старт и финиш, затем отметьте стены." />
            <Grid ColumnDefinitions="*,10,*">
              <StackPanel Grid.Column="0">
                <TextBlock Classes="caption" Text="Ширина" />
                <NumericUpDown Minimum="2" Maximum="20" Value="{Binding BoardWidth}" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Classes="caption" Text="Высота" />
                <NumericUpDown Minimum="2" Maximum="20" Value="{Binding BoardHeight}" />
              </StackPanel>
            </Grid>
            <WrapPanel>
              <Button Classes="secondary-action" Content="Применить размер" Command="{Binding ResizeBoardCommand}" />
              <Button Classes="secondary-action" Content="Очистить стены" Command="{Binding ClearWallsCommand}" />
              <Button Classes="secondary-action" Content="Очистить старт и финиш" Command="{Binding ClearEndpointsCommand}" />
              <Button Classes="secondary-action" Content="Сбросить всё" Command="{Binding ClearAllCommand}" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title" Text="Инструменты редактирования" />
            <TextBlock Classes="caption" Text="Повторный клик по стартовой клетке очищает и старт, и финиш." />
            <WrapPanel Orientation="Horizontal" ItemHeight="40">
              <Button Classes="toolbar-chip" Content="Старт" Click="StartToolButton_Click" />
              <Button Classes="toolbar-chip" Content="Финиш" Click="FinishToolButton_Click" />
              <Button Classes="toolbar-chip" Content="Стены" Click="WallToolButton_Click" />
              <Button Classes="toolbar-chip" Content="Ластик" Click="EraseToolButton_Click" />
            </WrapPanel>
            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Classes="caption" />
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="8">
            <TextBlock Classes="section-title" Text="Настройки решателя" />
            <CheckBox Content="Эвристика Варнсдорфа" IsChecked="{Binding UseWarnsdorff}" />
            <CheckBox Content="Отсечение по связности" IsChecked="{Binding UseConnectivity}" />
            <CheckBox Content="Backjumping" IsChecked="{Binding UseBackjumping}" />
            <WrapPanel Orientation="Horizontal">
              <Button Classes="primary-action" Content="Запустить текущую" Command="{Binding RunCurrentCommand}" />
              <Button Classes="secondary-action" Content="Запустить базовую + текущую" Command="{Binding RunBaselineAndCurrentCommand}" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title" Text="Результаты" />
            <ItemsControl ItemsSource="{Binding Results}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="result-item">
                    <StackPanel Spacing="8">
                      <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="{Binding Title}" FontWeight="SemiBold" />
                        <TextBlock DockPanel.Dock="Right" Classes="caption" Text="{Binding ExecutedAt, StringFormat='{}{0:HH:mm:ss}'}" />
                      </DockPanel>
                      <TextBlock Text="{Binding StatusText}" />
                      <WrapPanel>
                        <Border Classes="metric-badge"><TextBlock Text="{Binding Elapsed.TotalMilliseconds, StringFormat='{}{0:0.##} ms'}" /></Border>
                        <Border Classes="metric-badge"><TextBlock Text="{Binding ManagedMemoryDeltaBytes, Converter={x:Static local:ByteSizeConverter.Instance}}" /></Border>
                        <Border Classes="metric-badge"><TextBlock Text="{Binding WorkingSetDeltaBytes, Converter={x:Static local:ByteSizeConverter.Instance}}" /></Border>
                        <Border Classes="metric-badge"><TextBlock Text="{Binding Steps, StringFormat='{}шагов: {0}'}" /></Border>
                      </WrapPanel>
                      <TextBlock Classes="caption" TextWrapping="Wrap" Text="{Binding Note}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Column="2" RowDefinitions="Auto,14,*">
      <Border Classes="card" Padding="16">
        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <TextBlock Classes="section-title" Text="Сетка" />
          <TextBlock Classes="caption" Text="Поле автоматически подстраивается под окно." />
        </StackPanel>
      </Border>
      <controls:HamiltonianBoardView Grid.Row="2" />
    </Grid>
  </Grid>
</Window>
