<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SlidingPuzzle.Avalonia.Views.Controls"
        xmlns:local="clr-namespace:SlidingPuzzle.Avalonia.Converters"
        x:Class="SlidingPuzzle.Avalonia.Views.MainWindow"
        Title="Пятнашки"
        Width="1480"
        Height="940"
        MinWidth="1220"
        MinHeight="820"
        KeyDown="Window_KeyDown">
  <Grid>
    <Grid ColumnDefinitions="390,18,*" Margin="18" IsEnabled="{Binding IsInteractionEnabled}">
    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="16">
        <Border Classes="card">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title" Text="Настройка поля" />
            <Grid ColumnDefinitions="*,10,*">
              <StackPanel Grid.Column="0">
                <TextBlock Classes="caption" Text="Ширина" />
                <NumericUpDown Minimum="2" Maximum="6" Value="{Binding BoardWidth}" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Classes="caption" Text="Высота" />
                <NumericUpDown Minimum="2" Maximum="6" Value="{Binding BoardHeight}" />
              </StackPanel>
            </Grid>
            <StackPanel Spacing="8">
              <WrapPanel ItemWidth="170">
                <Button Width="170" Classes="secondary-action" Content="Случайно" Command="{Binding RandomizeCommand}" />
                <Button Width="170" Classes="secondary-action" Content="Задать глубину">
                  <Button.Flyout>
                    <Flyout Placement="Bottom">
                      <StackPanel Width="240" Spacing="8">
                        <TextBlock Classes="section-title" Text="Задать глубину" />
                        <TextBlock Classes="caption" Text="Введите целевую глубину от финального состояния. 0 или пусто = полностью случайная перестановка." TextWrapping="Wrap" />
                        <TextBox Watermark="Например: 20"
                                 Text="{Binding RandomShuffleMovesText}" />
                      </StackPanel>
                    </Flyout>
                  </Button.Flyout>
                </Button>
              </WrapPanel>
              <Button Width="170" Classes="secondary-action" Content="Собранная" Command="{Binding ResetSolvedCommand}" />
              <Button Width="170" Classes="secondary-action" Content="Импорт" Click="ImportButton_Click" />
              <Button Width="170" Classes="secondary-action" Content="Экспорт" Click="ExportButton_Click" />
              <Button Width="170" Classes="secondary-action" Content="Отменить" Command="{Binding UndoCommand}" />
            </StackPanel>
            <StackPanel Spacing="6">
              <TextBlock Classes="caption" Text="Режим редактирования" />
              <ToggleSwitch Classes="mode-toggle" IsChecked="{Binding IsEditMode}" />
            </StackPanel>
            <TextBlock Classes="caption" Text="" />
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title" Text="Управление" />
            <Border Classes="metric-badge"
                    Background="{Binding PlaybackBackgroundBrush}"
                    BorderBrush="{Binding PlaybackBorderBrush}"
                    BorderThickness="1">
              <TextBlock Text="{Binding PlaybackStatusText}" />
            </Border>
            <TextBlock Classes="caption" Text="{Binding StatusText}" TextWrapping="Wrap" />
            <TextBlock Classes="caption" Text="{Binding ProgressText}" />
            <WrapPanel>
              <Button Classes="secondary-action" Content="Пред. шаг" Command="{Binding StepBackwardCommand}" />
              <Button Classes="secondary-action" Content="След. шаг" Command="{Binding StepForwardCommand}" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="8">
            <TextBlock Classes="section-title" Text="Алгоритмы" />
            <ComboBox x:Name="AlgorithmComboBox"
                      SelectedItem="{Binding SelectedAlgorithm}"
                      ItemsSource="{Binding AlgorithmOptions}"
                      SelectionChanged="AlgorithmComboBox_SelectionChanged" />
            <WrapPanel>
              <Button Classes="primary-action solve-action" Content="Решить текущее поле" Command="{Binding RunCurrentCommand}" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="10">
            <DockPanel>
              <TextBlock DockPanel.Dock="Left" Classes="section-title" Text="Результаты" />
              <Button DockPanel.Dock="Right" Width="170" Classes="secondary-action" Content="Очистить результаты" Command="{Binding ClearResultsCommand}" />
            </DockPanel>
            <ItemsControl ItemsSource="{Binding Results}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="result-item">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                      <WrapPanel>
                        <Border Classes="metric-badge"><TextBlock Text="{Binding Elapsed.TotalMilliseconds, StringFormat='{}Время: {0:0.##} ms'}" /></Border>
                        <Border Classes="metric-badge"><TextBlock Text="{Binding ManagedMemoryDeltaBytes, Converter={x:Static local:ByteSizeConverter.Instance}, StringFormat='{}Память: {0}'}" /></Border>
                        <Border Classes="metric-badge"><TextBlock Text="{Binding Steps, StringFormat='{}ходов: {0}'}" /></Border>
                      </WrapPanel>
                      <TextBlock Text="{Binding StatusText}" />
                      <TextBlock Classes="caption" TextWrapping="Wrap" Text="{Binding Note}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Column="2" RowDefinitions="*,16,Auto">
      <controls:SlidingPuzzleBoardView />
      <Expander Grid.Row="2" IsExpanded="True" ExpandDirection="Up">
        <Expander.Header>
          <TextBlock Text="Маршрут решения" />
        </Expander.Header>
        <Border Classes="card" Padding="12">
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding RoutePreview}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="8" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="metric-badge"
                          Background="{Binding IsActive, Converter={x:Static local:ActiveChipBrushConverter.Instance}}">
                    <TextBlock Text="{Binding Text}" />
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>
      </Expander>
    </Grid>
    </Grid>

    <Border IsVisible="{Binding IsBusy}"
            Background="#AA12141A"
            ZIndex="99">
      <Border HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Classes="card"
              Padding="20">
        <StackPanel Spacing="12" Width="300">
          <TextBlock Classes="section-title"
                     Text="Выполняется поиск решения"
                     HorizontalAlignment="Center" />
          <TextBlock Classes="caption"
                     Text="Пожалуйста, подождите."
                     TextWrapping="Wrap"
                     HorizontalAlignment="Center"
                     TextAlignment="Center" />
          <ProgressBar IsIndeterminate="True" Height="8" />
          <Button Content="Прервать"
                  Classes="secondary-action"
                  Command="{Binding CancelRunCommand}" />
        </StackPanel>
      </Border>
    </Border>
  </Grid>
</Window>
