<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SlidingPuzzle.Avalonia.Views.Controls"
        xmlns:local="clr-namespace:SlidingPuzzle.Avalonia.Converters"
        x:Class="SlidingPuzzle.Avalonia.Views.MainWindow"
        Title="Sliding Puzzle Lab"
        Width="1480"
        Height="940"
        MinWidth="1220"
        MinHeight="820"
        KeyDown="Window_KeyDown">
  <Grid ColumnDefinitions="390,18,*" Margin="18">
    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="16">
        <Border Classes="card">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title" Text="Board configuration" />
            <TextBlock Classes="caption" Text="The right panel stays fit-to-view in v1. No free panning is needed for 4×4 and similar sizes." />
            <StackPanel>
              <TextBlock Classes="caption" Text="Size" />
              <NumericUpDown Minimum="2" Maximum="6" Value="{Binding Size}" />
            </StackPanel>
            <WrapPanel>
              <Button Classes="secondary-action" Content="Random" Command="{Binding RandomizeCommand}" />
              <Button Classes="secondary-action" Content="Solved" Command="{Binding ResetSolvedCommand}" />
              <Button Classes="secondary-action" Content="Import" Click="ImportButton_Click" />
              <Button Classes="secondary-action" Content="Export" Click="ExportButton_Click" />
              <Button Classes="secondary-action" Content="Undo" Command="{Binding UndoCommand}" />
            </WrapPanel>
            <StackPanel Spacing="6">
              <TextBlock Classes="caption" Text="Edit mode" />
              <ToggleSwitch Classes="mode-toggle" IsChecked="{Binding IsEditMode}" />
            </StackPanel>
            <TextBlock Classes="caption" Text="In play mode arrows and neighbour clicks move the blank tile. In edit mode drag any tile to swap positions." />
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="8">
            <TextBlock Classes="section-title" Text="Algorithm" />
            <ComboBox SelectedItem="{Binding SelectedAlgorithm}" ItemsSource="{Binding AlgorithmOptions}" />
            <WrapPanel>
              <Button Classes="primary-action" Content="Solve current board" Command="{Binding RunCurrentCommand}" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title" Text="Playback and manual control" />
            <Border Classes="metric-badge" Background="{Binding PlaybackBackgroundBrush}" BorderBrush="{Binding PlaybackBorderBrush}" BorderThickness="1">
              <TextBlock Text="{Binding PlaybackStatusText}" />
            </Border>
            <TextBlock Classes="caption" Text="{Binding StatusText}" TextWrapping="Wrap" />
            <TextBlock Classes="caption" Text="{Binding ProgressText}" />
            <WrapPanel>
              <Button Classes="secondary-action" Content="Prev step" Command="{Binding StepBackwardCommand}" />
              <Button Classes="secondary-action" Content="Next step" Command="{Binding StepForwardCommand}" />
            </WrapPanel>
            <Grid ColumnDefinitions="60,60,60" RowDefinitions="60,60,60" HorizontalAlignment="Center">
              <Button Grid.Column="1" Grid.Row="0" Classes="toolbar-chip" Content="↑" Command="{Binding MoveUpCommand}" />
              <Button Grid.Column="0" Grid.Row="1" Classes="toolbar-chip" Content="←" Command="{Binding MoveLeftCommand}" />
              <Button Grid.Column="2" Grid.Row="1" Classes="toolbar-chip" Content="→" Command="{Binding MoveRightCommand}" />
              <Button Grid.Column="1" Grid.Row="2" Classes="toolbar-chip" Content="↓" Command="{Binding MoveDownCommand}" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title" Text="Results" />
            <ItemsControl ItemsSource="{Binding Results}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="result-item">
                    <StackPanel Spacing="8">
                      <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                      <WrapPanel>
                        <Border Classes="metric-badge"><TextBlock Text="{Binding Elapsed.TotalMilliseconds, StringFormat='{}{0:0.##} ms'}" /></Border>
                        <Border Classes="metric-badge"><TextBlock Text="{Binding ManagedMemoryDeltaBytes, Converter={x:Static local:ByteSizeConverter.Instance}}" /></Border>
                        <Border Classes="metric-badge"><TextBlock Text="{Binding WorkingSetDeltaBytes, Converter={x:Static local:ByteSizeConverter.Instance}}" /></Border>
                        <Border Classes="metric-badge"><TextBlock Text="{Binding Steps, StringFormat='{}moves: {0}'}" /></Border>
                      </WrapPanel>
                      <TextBlock Text="{Binding StatusText}" />
                      <TextBlock Classes="caption" TextWrapping="Wrap" Text="{Binding Note}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Column="2" RowDefinitions="*,16,Auto">
      <controls:SlidingPuzzleBoardView />
      <Expander Grid.Row="2" IsExpanded="True">
        <Expander.Header>
          <TextBlock Text="Solution route" />
        </Expander.Header>
        <Border Classes="card" Padding="12">
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding RoutePreview}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="8" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="metric-badge" Background="{Binding IsActive, Converter={x:Static local:ActiveChipBrushConverter.Instance}}">
                    <TextBlock Text="{Binding Text}" />
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>
      </Expander>
    </Grid>
  </Grid>
</Window>